{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Telar",
	"scopeName": "source.telar",
	"fileTypes": [
		"telar"
	],
	"patterns": [
		{
      		"include": "#comentarios"
		},
		{
			"include": "#textos"
		},
		{
			"include": "#numeros"
		},
		{
			"include": "#palabras-clave-estructura"
		},
		{
			"include": "#palabras-clave-contenido"
		},
		{
			"include": "#palabras-clave-logica"
		},
		{
			"include": "#palabras-clave-modificadores"
		},
		{
			"include": "#nombres-propios"
		},
		{
			"include": "#operadores"
		},
		{
			"include": "#identificadores"
		}
	],
	"repository": {
		"comentarios": {
			"name": "comment.line.hash.telar",
			"match": "#.*$"
		},
		"textos": {
			"name": "string.quoted.double.telar",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.telar",
					"match": "\\\\."
				}
			]
		},
		"numeros": {
			"name": "constant.numeric.telar",
			"match": "\\b[0-9]+(\\.[0-9]+)?\\b"
		},
		"palabras-clave-estructura": {
			"name": "keyword.control.telar",
			"match": "\\b(aplicaci처n|aplicacion|p찼gina|pagina|datos|en|idioma)\\b"
		},
		"palabras-clave-contenido": {
			"name": "keyword.other.content.telar",
			"match": "\\b(t챠tulo|titulo|descripci처n|descripcion|mostrar|bot처n|boton|campo|tipo)\\b"
		},
		"palabras-clave-logica": {
			"name": "keyword.control.flow.telar",
			"match": "\\b(si|no|el|la|est찼|esta|es|hay|falla|funciona)\\b"
		},
		"palabras-clave-modificadores": {
			"name": "keyword.other.modifier.telar",
			"match": "\\b(m찼ximo|maximo|ordenados|filtrados|por|recientes|para|m처vil|movil|cach챕|cache|reintentar|minutos|horas|segundos|optimizar|ir|hacer|a)\\b"
		},
		"nombres-propios": {
			"name": "entity.name.type.telar",
			"match": "\\b[A-Z횁횋횒횙횣횥횗][a-z찼챕챠처첬체챰A-Z횁횋횒횙횣횥횗0-9]*\\b"
		},
		"operadores": {
			"name": "keyword.operator.telar",
			"match": "[><=:]"
		},
		"identificadores": {
			"name": "variable.other.telar",
			"match": "\\b[a-z찼챕챠처첬체챰][a-z찼챕챠처첬체챰A-Z횁횋횒횙횣횥횗0-9]*(\\.[a-z찼챕챠처첬체챰][a-z찼챕챠처첬체챰A-Z횁횋횒횙횣횥횗0-9]*)*\\b"
		}
	}
}
