{
  "name": "telar",
  "displayName": "Telar",
  "description": "Soporte para el lenguaje Telar — resaltado de sintaxis para archivos .telar",
  "version": "0.1.0",
  "publisher": "davidbc01",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/davidbc01/telar-vscode"
  },
  "contributes": {
    "languages": [
      {
        "id": "telar",
        "aliases": ["Telar", "telar"],
        "extensions": [".telar"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "telar",
        "scopeName": "source.telar",
        "path": "./syntaxes/telar.tmLanguage.json"
      }
    ]
  }
}
